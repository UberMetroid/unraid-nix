<?xml version='1.0' standalone='yes'?>
<!DOCTYPE PLUGIN [
  <!ENTITY name      "nix">
  <!ENTITY author    "UberMetroid">
  <!ENTITY version   "2026.06.25.31">
  <!ENTITY launch    "Settings/nix">
  <!ENTITY plugdir   "/boot/config/plugins/&name;">
  <!ENTITY usrdir    "/usr/local/emhttp/plugins/&name;">
]>
<PLUGIN name="Nix" author="&author;" version="&version;" launch="&launch;" icon="Nix.png" support="https://github.com/UberMetroid/unraid-nix/issues" pluginURL="https://raw.githubusercontent.com/UberMetroid/unraid-nix/main/nix.plg">

  <CHANGES>
    ## nix package manager plugin
    ### 2026.06.25.31
    - Renamed Custom Flakes tab to Install Flake to match settings vocabulary.
    ### 2026.06.25.30
    - Linked search result package names directly to their official search.nixos.org details page in a new window.
    - Configured explicit wordwrap and break-word rules for search descriptions in the stylesheet.
    ### 2026.06.25.29
    - Forced dark backgrounds on tables to fix the white-on-white text contrast issue under light Unraid themes.
    - Hidden "Install CLI" by default and made it a toggleable option in the Settings tab, leaving only "Add Service" in search results for a cleaner UI.
    - Configured search action buttons to lay out cleanly inside a flex stack to prevent overflow.
    ### 2026.06.25.28
    - Adjusted search and active flakes tables to use a fixed table layout with proportional column widths to prevent page overflow.
    ### 2026.06.25.27
    - Fixed package search failures by calling the absolute Nix binary path in the Rust helper.
    - Integrated "Add Service" searches to redirect to Custom Flakes with auto-filled forms and sandboxing defaults.
    ### 2026.06.25.26
    - Moved the Nix System Daemon status control panel from Active Flakes tab to the Settings tab.
    ### 2026.06.25.25
    - Renamed the first tab from Services to Active Flakes to match vocabulary.
    ### 2026.06.25.24
    - Reorganized layout into 5 dedicated tabs: Services, Flake Store, Custom Flakes, Logs, Settings.
    - Set the default Nix Store Path to /mnt/user/system/nix (next to Docker in the system share).
    - Integrated standard Unraid file-browser path selector on Custom Flakes paths (Appdata and Media).
    ### 2026.06.25.23
    - Restored the store path settings field to a standard text input integrated with Dynamix's folder browser popup picker (acts like Docker/VM settings).
    - Added a control panel on the Services tab with running status and Start/Stop buttons for the Nix System Daemon/supervisor.
    ### 2026.06.25.22
    - Replaced the text input field for Nix Store Path with a select dropdown populated dynamically from available Unraid Cache pools and user shares. Added support for toggleable custom path entry.
    ### 2026.06.25.21
    - Added Tabs="true" to nix.page and set the launch target to Settings/nix, allowing Dynamix to naturally render sub-tabs without redirection hacks.
    ### 2026.06.25.20
    - Fixed sub-tab rendering by isolating the /usr/local/emhttp/plugins/Nix directory to only contain icons and README, preventing Dynamix from scanning duplicate .page files.
    ### 2026.06.25.19
    - Switched from printf to safe echo statements for generating the local README.md description to bypass nested parser percent sign evaluations.
    ### 2026.06.25.18
    - Reverted launch target to Settings/nix_services and restored nix.page redirect to ensure the tabbed layout renders correctly on settings page load.
    ### 2026.06.25.17
    - Escaped percent sign in printf statement to prevent truncation of the plugin description.
    ### 2026.06.25.16
    - Fixed XML parse error during plugin installation by replacing bash heredoc angle brackets with printf.
    ### 2026.06.25.15
    - Formatted Unraid Plugins tab local README.md description with bold title and line break.
    ### 2026.06.25.14
    - Restored the parent route launch target to Settings/nix (previously Settings/nix_services) and removed the JavaScript redirect inside nix.page.
    - This allows Dynamix to natively render and display the sub-tabs (Services, Flakes Browser, Settings) under the main Nix settings page.
    ### 2026.06.25.13
    - Removed unused Multi-User settings configuration group from the WebGUI.
    - Implemented dynamic detection for the default Nix Store Path to locate /system/nix on any mounted cache pool, custom pool, or array share.
    ### 2026.06.25.12
    - Added premium flavor text and step indicators during plugin installation.
    ### 2026.06.25.11
    - Wrote a minimal inline README.md for the Unraid Plugins GUI containing only the single-sentence overview.
    ### 2026.06.25.10
    - Shortened plugin overview description.
    ### 2026.06.25.9
    - Fixed missing icon, overview description, and support link in Unraid Plugins page by adding case-sensitive directory and file symlinks.
    - Updated icon attribute to point to the local Nix.png file.
    ### 2026.06.25.8
    - Added explicit icon and support URL attributes to the PLUGIN tag to restore logo and link to GitHub issues page.
    ### 2026.06.25.7
    - Set settings launch target directly to Settings/nix_services.
    - Added a JavaScript redirect inside nix.page to route Settings/Nix requests to the active sub-tab.
    ### 2026.06.25.6
    - Capitalized display name to "Nix" on the Plugins page.
    - Added README.md download to register the plugin description in the GUI.
    ### 2026.06.25.5
    - Fixed case-sensitivity for child tab Menu properties (pointing to lowercase nix) to successfully link them to the parent nix.page.
    ### 2026.06.25.4
    - Updated Menu mapping to Utilities to display the Nix icon under User Utilities in the Settings menu.
    ### 2026.06.25.3
    - Cleared manual HTML body from nix.page to allow Unraid Dynamix tab auto-generation.
    - Replaced short PHP open tags in nix_settings.page with standard tags.
    - Injected styles.css stylesheet loading links directly inside sub-tab page bodies.
    ### 2026.06.25.2
    - Added UberMetroid branding and logo assets.
    - Updated repository references and release hooks.
    ### 2026.06.25
    - Initial release.
    - 100% Rust-backed API and sandbox orchestration.
    - bubblewrap declarative sandboxing for share isolation.
    - process-compose daemon integration.
  </CHANGES>

  <!-- INSTALL LIFE CYCLE -->
  <FILE Run="/bin/bash">
    <INLINE>
      echo "------------------------------------------------------------------"
      echo " Installing Nix Package Manager Plugin (by &author;)"
      echo "------------------------------------------------------------------"

      # 1. Clean runtime directory
      echo "--> Initializing plugin runtime and directory configurations..."
      rm -rf "&usrdir;"
      mkdir -p "&usrdir;"
      mkdir -p "&plugdir;"

      # GitHub URL prefix for raw resources
      GITHUB_RAW="https://raw.githubusercontent.com/UberMetroid/unraid-nix/main"

      # 2. Download and copy compiled Rust helper binary
      echo "--> Downloading compiled Rust helper binary (nix-helper)..."
      curl -sSf -L --create-dirs -o "&plugdir;/nix-helper" "${GITHUB_RAW}/nix-helper"
      cp "&plugdir;/nix-helper" "&usrdir;/nix-helper"
      chmod +x "&usrdir;/nix-helper"

      # 3. Download and install WebGUI pages
      echo "--> Downloading Dynamix WebGUI pages and assets..."
      for file in nix.page nix_services.page nix_search.page nix_custom.page nix_logs.page nix_settings.page nix_dashboard.page api.php styles.css nix.png nix.svg; do
          curl -sSf -L -o "&usrdir;/$file" "${GITHUB_RAW}/web/$file"
      done
      
      # Write a minimal README.md containing only the overview for the Unraid Plugins GUI screen
      echo "**Nix**" > "&usrdir;/README.md"
      echo "" >> "&usrdir;/README.md"
      echo "A native, 100% Rust-backed plugin to run the Nix package manager and manage Nix Flakes natively on Unraid." >> "&usrdir;/README.md"

      # Create case-sensitive directory and symlinks for Unraid Plugin Manager icon/README lookup
      rm -rf /usr/local/emhttp/plugins/Nix
      mkdir -p /usr/local/emhttp/plugins/Nix
      ln -sf /usr/local/emhttp/plugins/nix/nix.png /usr/local/emhttp/plugins/Nix/Nix.png
      ln -sf /usr/local/emhttp/plugins/nix/nix.svg /usr/local/emhttp/plugins/Nix/Nix.svg
      ln -sf /usr/local/emhttp/plugins/nix/README.md /usr/local/emhttp/plugins/Nix/README.md

      # 4. Download and install integration scripts
      echo "--> Downloading system integration scripts..."
      mkdir -p "&plugdir;/scripts"
      for script in rc.nix-daemon nix-profile.sh event_disks_mounted event_stopping_svcs; do
          curl -sSf -L -o "&plugdir;/scripts/$script" "${GITHUB_RAW}/scripts/$script"
          chmod +x "&plugdir;/scripts/$script"
      done

      # 5. Place configuration scripts in system directories
      echo "--> Ingesting daemon control and profile scripts..."
      cp "&plugdir;/scripts/rc.nix-daemon" /etc/rc.d/rc.nix-daemon
      cp "&plugdir;/scripts/nix-profile.sh" /etc/profile.d/nix.sh
      chmod +x /etc/rc.d/rc.nix-daemon /etc/profile.d/nix.sh

      # 6. Place event hooks in emhttp directory
      echo "--> Configuring Unraid system event hooks..."
      mkdir -p "&usrdir;/event"
      cp "&plugdir;/scripts/event_disks_mounted" "&usrdir;/event/disks_mounted"
      cp "&plugdir;/scripts/event_stopping_svcs" "&usrdir;/event/stopping_svcs"
      chmod +x "&usrdir;/event/disks_mounted" "&usrdir;/event/stopping_svcs"

      # 7. Check if array is already started; trigger disks_mounted if yes
      if [ -d "/mnt/user" ]; then
          echo "--> Storage Array is active. Starting Nix environment setup..."
          &usrdir;/event/disks_mounted
      fi

      echo "------------------------------------------------------------------"
      echo " Installation of Nix plugin completed successfully!"
      echo " Natively run flakes with zero container or VM overhead."
      echo "------------------------------------------------------------------"
    </INLINE>
  </FILE>

  <!-- UNINSTALL LIFE CYCLE -->
  <FILE Run="/bin/bash" Method="remove">
    <INLINE>
      echo "Uninstalling &name; plugin..."

      # 1. Stop services and unmount store
      if [ -f "&usrdir;/event/stopping_svcs" ]; then
          &usrdir;/event/stopping_svcs
      fi

      # 2. Remove runtime directories and scripts
      rm -rf "&usrdir;"
      rm -rf /usr/local/emhttp/plugins/Nix
      rm -f /etc/rc.d/rc.nix-daemon
      rm -f /etc/profile.d/nix.sh

      # Note: Persistent configurations and /nix store folder are NOT deleted
      # to prevent user data loss. They are left intact under the configured paths.
      
      echo "Uninstall of &name; plugin completed."
    </INLINE>
  </FILE>

</PLUGIN>
