{
  "name": "seafile",
  "display_name": "Seafile Sync Client (Daemon)",
  "description": "Seafile client sync daemon (seaf-daemon) for syncing local directories with a remote Seafile server.",
  "url": "https://www.seafile.com/",
  "command": "exec nix run nixpkgs#seafile-shared -- seaf-daemon -f -c /config",
  "default_ports": [
    {
      "host": 8000,
      "container": 8000,
      "label": "HTTP"
    }
  ],
  "icon": "fa-cloud"
}
