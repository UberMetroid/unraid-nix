{
  "name": "openhab",
  "display_name": "OpenHAB",
  "description": "OpenHAB Smart Home",
  "url": "https://www.openhab.org/",
  "command": "exec nix run nixpkgs#openhab",
  "default_ports": [
    {
      "host": 8080,
      "container": 8080,
      "label": "HTTP"
    },
    {
      "host": 8443,
      "container": 8443,
      "label": "HTTPS"
    }
  ],
  "icon": "fa-home"
}