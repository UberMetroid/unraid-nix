{
  "name": "nginx-proxy-manager",
  "display_name": "Nginx Proxy Manager",
  "description": "Nginx Proxy Manager GUI",
  "url": "https://nginxproxymanager.com/",
  "command": "exec nix run nixpkgs#nginx-proxy-manager",
  "default_ports": [
    {
      "host": 81,
      "container": 81,
      "label": "Admin Web"
    },
    {
      "host": 80,
      "container": 80,
      "label": "HTTP"
    },
    {
      "host": 443,
      "container": 443,
      "label": "HTTPS"
    }
  ]
}