<script>
var isLogHovered = false;
var logRefreshInterval = null;
var logPollCounter = 0;

function loadLogs(isAutoRefresh) {
    var type = document.getElementById('nix-log-select').value;
    var container = document.getElementById('nix-log-content');
    var refreshBtn = $('#nix-log-refresh-btn');
    
    // Check if user is scrolled to the bottom before loading new content
    var isAtBottom = (container.scrollHeight - container.clientHeight - container.scrollTop) < 40;
    if (container.scrollHeight <= container.clientHeight) {
        isAtBottom = true;
    }

    if (!isAutoRefresh) {
        refreshBtn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> Loading...');
    }

    var checkServices = (!isAutoRefresh || (logPollCounter % 6 === 0)) ? '1' : '0';
    if (isAutoRefresh) {
        logPollCounter++;
    }
    $.get('/plugins/nix/api.php?action=nix-sys-logs&type=' + type + '&lines=1000&check_services=' + checkServices, function(resp) {
        if (resp.success) {
            var rawText = resp.content;
            var showInfo = document.getElementById('nix-log-filter-info').checked;
            var showWarn = document.getElementById('nix-log-filter-warn').checked;
            var showError = document.getElementById('nix-log-filter-error').checked;
            var showDebug = document.getElementById('nix-log-filter-debug').checked;
            var showUntagged = document.getElementById('nix-log-filter-untagged').checked;
            
            var lines = rawText.split('\n');
            var filteredLines = [];
            
            for (var i = 0; i < lines.length; i++) {
                var line = lines[i];
                var lineTrimmed = line.trim();
                if (!lineTrimmed) continue;
                
                var displayLine = line;
                var logLevel = 'untagged';
                
                // Try parsing as JSON first (common for process-compose service logs)
                if (lineTrimmed.indexOf('{') === 0) {
                    try {
                        var parsed = JSON.parse(lineTrimmed);
                        var time = parsed.time || '';
                        var message = parsed.message || parsed.msg || '';
                        var level = parsed.level || '';
                        var processName = parsed.process || '';
                        
                        logLevel = level.toLowerCase();
                        
                        var timePrefix = '';
                        if (time) {
                            var timeDisplay = time.length >= 19 ? time.substring(0, 19).replace('T', ' ') : time;
                            timePrefix = '[' + timeDisplay + '] ';
                        }
                        
                        var procPrefix = processName ? '(' + processName + ') ' : '';
                        var levelStr = level ? '[' + level.toUpperCase() + '] ' : '';
                        
                        displayLine = timePrefix + procPrefix + levelStr + message;
                    } catch (e) {
                        // Keep raw line if JSON parsing fails
                    }
                }
                
                var lowerLine = displayLine.toLowerCase();
                
                var isInfo = logLevel === 'info' || logLevel === 'inf' || lowerLine.indexOf('[info]') !== -1 || lowerLine.indexOf('[inf]') !== -1 || lowerLine.indexOf('info:') !== -1;
                var isWarn = logLevel === 'warn' || logLevel === 'warning' || logLevel === 'wrn' || lowerLine.indexOf('[warn]') !== -1 || lowerLine.indexOf('[warning]') !== -1 || lowerLine.indexOf('[wrn]') !== -1 || lowerLine.indexOf('warning:') !== -1;
                var isError = logLevel === 'error' || logLevel === 'fatal' || logLevel === 'err' || lowerLine.indexOf('[error]') !== -1 || lowerLine.indexOf('[fatal]') !== -1 || lowerLine.indexOf('[err]') !== -1 || lowerLine.indexOf('error:') !== -1 || lowerLine.indexOf('fatal:') !== -1;
                var isDebug = logLevel === 'debug' || logLevel === 'dbg' || lowerLine.indexOf('[debug]') !== -1 || lowerLine.indexOf('[dbg]') !== -1 || lowerLine.indexOf('debug:') !== -1;
                
                var matchesAny = isInfo || isWarn || isError || isDebug;
                
                if (isInfo && !showInfo) continue;
                if (isWarn && !showWarn) continue;
                if (isError && !showError) continue;
                if (isDebug && !showDebug) continue;
                
                // If it doesn't match any level explicitly, check the Untagged filter
                if (!matchesAny && !showUntagged) continue;
                
                filteredLines.push(displayLine);
            }
            
            var filteredText = filteredLines.join('\n');
            var escaped = $('<div>').text(filteredText).html();
            
            // Highlight bracket log levels (case-sensitive replacements first)
            escaped = escaped.replace(/\[ERROR\]/g, '<span style="color: #ef4444; font-weight: bold;">[ERROR]</span>');
            escaped = escaped.replace(/\[FATAL\]/g, '<span style="color: #ef4444; font-weight: bold;">[FATAL]</span>');
            escaped = escaped.replace(/\[ERR\]/g, '<span style="color: #ef4444; font-weight: bold;">[ERR]</span>');
            
            escaped = escaped.replace(/\[WARN\]/g, '<span style="color: #f59e0b; font-weight: bold;">[WARN]</span>');
            escaped = escaped.replace(/\[WARNING\]/g, '<span style="color: #f59e0b; font-weight: bold;">[WARNING]</span>');
            escaped = escaped.replace(/\[WRN\]/g, '<span style="color: #f59e0b; font-weight: bold;">[WRN]</span>');
            
            escaped = escaped.replace(/\[INFO\]/g, '<span style="color: var(--nix-accent); font-weight: bold;">[INFO]</span>');
            escaped = escaped.replace(/\[INF\]/g, '<span style="color: var(--nix-accent); font-weight: bold;">[INF]</span>');
            
            escaped = escaped.replace(/\[DEBUG\]/g, '<span style="color: var(--nix-text-muted);">[DEBUG]</span>');
            escaped = escaped.replace(/\[DBG\]/g, '<span style="color: var(--nix-text-muted);">[DBG]</span>');
            
            // Case-insensitive replacements for systemd or standard linux headers
            escaped = escaped.replace(/(error:)/ig, '<span style="color: #ef4444; font-weight: bold;">$1</span>');
            escaped = escaped.replace(/(warning:)/ig, '<span style="color: #f59e0b; font-weight: bold;">$1</span>');
            escaped = escaped.replace(/(info:)/ig, '<span style="color: var(--nix-accent); font-weight: bold;">$1</span>');
            escaped = escaped.replace(/(debug:)/ig, '<span style="color: var(--nix-text-muted);">$1</span>');
            
            // Format timestamps and process prefixes beautifully
            escaped = escaped.replace(/^(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})/gm, '<span style="color: var(--nix-text-muted); font-weight: 500;">$1</span>');
            escaped = escaped.replace(/\[(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})\]/g, '<span style="color: var(--nix-text-muted); font-weight: 500;">[$1]</span>');
            escaped = escaped.replace(/(\]\s*)\(([a-zA-Z0-9_-]+)\)/g, '$1<span style="color: #38bdf8; font-weight: 500;">($2)</span>');
            escaped = escaped.replace(/^(\s*)\(([a-zA-Z0-9_-]+)\)/gm, '$1<span style="color: #38bdf8; font-weight: 500;">($2)</span>');
            
            container.innerHTML = escaped;
            
            // Re-scroll only if user was at bottom
            if (isAtBottom) {
                container.scrollTop = container.scrollHeight;
            }

            // Dynamically sync service log dropdown options
            if (resp && Array.isArray(resp.service_logs)) {
                var select = $('#nix-log-select');
                var servicesGroup = select.find('optgroup[label="Nix Services"]');
                
                if (resp.service_logs.length > 0) {
                    if (servicesGroup.length === 0) {
                        servicesGroup = $('<optgroup label="Nix Services"></optgroup>');
                        select.append(servicesGroup);
                    }
                    
                    var existingServices = {};
                    servicesGroup.find('option').each(function() {
                        var val = $(this).val().substring(8); // strip 'service:'
                        existingServices[val] = this;
                    });
                    
                    resp.service_logs.forEach(function(name) {
                        if (!existingServices[name]) {
                            servicesGroup.append($('<option>', {
                                value: 'service:' + name,
                                text: name
                            }));
                        } else {
                            delete existingServices[name];
                        }
                    });
                    
                    var selectedVal = select.val();
                    var selectedOptionWasRemoved = false;
                    for (var name in existingServices) {
                        if ($(existingServices[name]).val() === selectedVal) {
                            selectedOptionWasRemoved = true;
                        }
                        $(existingServices[name]).remove();
                    }
                    
                    if (servicesGroup.find('option').length === 0) {
                        servicesGroup.remove();
                    }
                    
                    if (selectedOptionWasRemoved) {
                        select.val('plugin');
                        loadLogs(false);
                    }
                } else {
                    var selectedVal = select.val();
                    if (selectedVal && selectedVal.indexOf('service:') === 0) {
                        select.val('plugin');
                        loadLogs(false);
                    }
                    servicesGroup.remove();
                }
            }
        } else {
            container.innerHTML = "<span style='color: #ef4444;'>Error loading logs: " + $('<div>').text(resp.error).html() + "</span>";
        }
        if (!isAutoRefresh) {
            refreshBtn.prop('disabled', false).html('<i class="fa fa-refresh"></i> Refresh');
        }
    }, 'json').fail(function() {
        container.innerHTML = "<span style='color: #ef4444;'>Failed to fetch log entries from server. Check network connection.</span>";
        if (!isAutoRefresh) {
            refreshBtn.prop('disabled', false).html('<i class="fa fa-refresh"></i> Refresh');
        }
    });
}

function downloadDiagnostics() {
    window.location.href = '/plugins/nix/api.php?action=download-diagnostics';
}

function copyLogsToClipboard() {
    var content = document.getElementById('nix-log-content').innerText;
    navigator.clipboard.writeText(content).then(function() {
        showNotice("Logs copied to clipboard!", "success");
    }, function() {
        showNotice("Failed to copy logs.", "error");
    });
}

$(function() {
    loadLogs();
    
    // Pause auto-refresh on hover
    $('#nix-log-content').hover(
        function() { isLogHovered = true; },
        function() { isLogHovered = false; }
    );
    
    // Auto-refresh every 5s if not hovered, automatically cleans up on navigation/invisibility
    if (logRefreshInterval) clearInterval(logRefreshInterval);
    logRefreshInterval = setInterval(function() {
        if (!isLogHovered) {
            var container = document.getElementById('nix-log-content');
            if (!container) {
                clearInterval(logRefreshInterval);
                return;
            }
            if (document.hidden || !$(container).is(':visible')) {
                return;
            }
            loadLogs(true);
        }
    }, 5000);
});
</script>

</div>