echo "<div class=\"nix-plugin-container theme-{$nix_theme}\">";

$service_logs = [];
if (is_dir('/var/log/nix-services')) {
    $files = glob('/var/log/nix-services/*.log');
    if ($files !== false) {
        foreach ($files as $f) {
            $name = basename($f, '.log');
            $service_logs[$name] = $f;
        }
    }
}
ksort($service_logs);
?>

