        <a href="/Settings/nix_search" class="nix-btn" style="text-decoration: none; margin: 0; display: inline-flex; align-items: center; gap: 6px;"><i class="fa fa-arrow-left"></i> Back to Flake Store</a>
    </div>
    <p class="nix-subtext" style="margin-top: -15px;">Run or daemonize any custom flake from GitHub or a local directory.</p>
    
    <form id="nix-install-custom-form" onsubmit="installCustomFlake(event)">
        <div class="nix-form-group">
            <label for="custom-uri">Flake URI / Preset Name:</label>
            <input type="text" id="custom-uri" placeholder="e.g. nixpkgs#radarr or github:user/repo#service-bin" required oninput="updatePresetInfo()">
        </div>
        
