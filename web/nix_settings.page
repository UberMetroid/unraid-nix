<script src="/plugins/nix/nix.js"></script>
<?php
$cfg_file = "/boot/config/plugins/nix/nix.cfg";
$nix_cfg = [];
if (file_exists($cfg_file)) {
    $nix_cfg = parse_ini_file($cfg_file);
}

if (!function_exists('detect_default_store_path')) {
    function detect_default_store_path() {
        $cfg_file = '/boot/config/shares/system.cfg';
        if (file_exists($cfg_file)) {
            $share_cfg = parse_ini_file($cfg_file);
            if ($share_cfg !== false) {
                $pool = isset($share_cfg['shareCachePool']) ? trim($share_cfg['shareCachePool'], '"') : '';
                if (empty($pool) && isset($share_cfg['shareUseCache'])) {
                    $use_cache = trim($share_cfg['shareUseCache'], '"');
                    if (in_array($use_cache, ['yes', 'prefer', 'only'])) {
                        $pool = 'cache';
                    }
                }
                if (!empty($pool) && is_dir("/mnt/" . $pool . "/system")) {
                    return "/mnt/" . $pool . "/system/nix";
                }
            }
        }
        
        if (is_dir('/mnt/user/system')) {
            return '/mnt/user/system/nix';
        }
        return '';
    }
}

if (!function_exists('detect_appdata_root')) {
    function detect_appdata_root() {
        $cfg_file = '/boot/config/shares/appdata.cfg';
        if (file_exists($cfg_file)) {
            $share_cfg = parse_ini_file($cfg_file);
            if ($share_cfg !== false) {
                $pool = isset($share_cfg['shareCachePool']) ? trim($share_cfg['shareCachePool'], '"') : '';
                if (empty($pool) && isset($share_cfg['shareUseCache'])) {
                    $use_cache = trim($share_cfg['shareUseCache'], '"');
                    if (in_array($use_cache, ['yes', 'prefer', 'only'])) {
                        $pool = 'cache';
                    }
                }
                if (!empty($pool) && is_dir("/mnt/" . $pool . "/appdata")) {
                    return "/mnt/" . $pool . "/appdata";
                }
            }
        }
        
        if (is_dir('/mnt/user/appdata')) {
            return '/mnt/user/appdata';
        }

        return '';
    }
}

// Set defaults
$store_path = isset($nix_cfg['NIX_STORE_PATH']) ? $nix_cfg['NIX_STORE_PATH'] : detect_default_store_path();
$default_appdata_path = isset($nix_cfg['DEFAULT_APPDATA_PATH']) ? $nix_cfg['DEFAULT_APPDATA_PATH'] : detect_appdata_root();
$autostart = isset($nix_cfg['AUTOSTART_FLAKES']) ? $nix_cfg['AUTOSTART_FLAKES'] : 'yes';
$show_in_nav = isset($nix_cfg['SHOW_IN_NAVIGATION']) ? $nix_cfg['SHOW_IN_NAVIGATION'] : 'yes';
$enable_sandbox = isset($nix_cfg['ENABLE_STORAGE_SANDBOX']) ? $nix_cfg['ENABLE_STORAGE_SANDBOX'] : 'yes';
$allow_source_builds = isset($nix_cfg['ALLOW_SOURCE_BUILDS']) ? $nix_cfg['ALLOW_SOURCE_BUILDS'] : 'no';
$filter_presets_by_hardware = isset($nix_cfg['FILTER_PRESETS_BY_HARDWARE']) ? $nix_cfg['FILTER_PRESETS_BY_HARDWARE'] : 'yes';
$enable_pid_isolation = isset($nix_cfg['ENABLE_PID_ISOLATION']) ? $nix_cfg['ENABLE_PID_ISOLATION'] : 'yes';
$enable_uts_isolation = isset($nix_cfg['ENABLE_UTS_ISOLATION']) ? $nix_cfg['ENABLE_UTS_ISOLATION'] : 'yes';
$enable_ipc_isolation = isset($nix_cfg['ENABLE_IPC_ISOLATION']) ? $nix_cfg['ENABLE_IPC_ISOLATION'] : 'yes';
$auto_gc = isset($nix_cfg['AUTO_GC']) ? $nix_cfg['AUTO_GC'] : 'no';
$store_quota = isset($nix_cfg['NIX_STORE_QUOTA']) ? $nix_cfg['NIX_STORE_QUOTA'] : '30';
$build_cores = isset($nix_cfg['BUILD_CORES']) ? $nix_cfg['BUILD_CORES'] : '0';
$build_jobs = isset($nix_cfg['BUILD_JOBS']) ? $nix_cfg['BUILD_JOBS'] : '0';
$gc_min_free = isset($nix_cfg['GC_MIN_FREE']) ? $nix_cfg['GC_MIN_FREE'] : '5';
$gc_max_free = isset($nix_cfg['GC_MAX_FREE']) ? $nix_cfg['GC_MAX_FREE'] : '10';
$nix_channel = isset($nix_cfg['NIX_CHANNEL']) ? $nix_cfg['NIX_CHANNEL'] : 'nixos-unstable';
$settings_confirmed = isset($nix_cfg['SETTINGS_CONFIRMED']) ? $nix_cfg['SETTINGS_CONFIRMED'] : 'no';

if ($settings_confirmed !== 'yes') {
    $store_path = '';
    $default_appdata_path = '';
}

$num_flakes = 0;
$meta_dir = "/boot/config/plugins/nix/metadata";
if (is_dir($meta_dir)) {
    $meta_files = glob($meta_dir . "/*.json");
    if ($meta_files !== false) {
        $num_flakes = count($meta_files);
    }
}
$suggested_quota = 15 + ($num_flakes * 3);

exec("/etc/rc.d/rc.nix-daemon status 2>/dev/null", $status_output, $status_code);
$is_nix_running = ($status_code === 0);
// Hardware capability detection
$cpu_info = shell_exec('cat /proc/cpuinfo 2>/dev/null');
$supports_intel = (strpos($cpu_info, ' vmx ') !== false);
$supports_amd = (strpos($cpu_info, ' svm ') !== false);

$kvm_status = 'inactive';
$kvm_details = 'Not Supported';

if (trim(shell_exec('[ -c /dev/kvm ] && echo "yes" || echo "no"')) === 'yes') {
    $kvm_status = 'active';
    if ($supports_intel) {
        $kvm_details = 'Intel VT-x (Active)';
    } elseif ($supports_amd) {
        $kvm_details = 'AMD-V (Active)';
    } else {
        $kvm_details = 'Generic KVM (Active)';
    }
} else {
    if ($supports_intel || $supports_amd) {
        $kvm_status = 'disabled';
        $kvm_details = ($supports_intel ? 'Intel VT-x' : 'AMD-V') . ' (Disabled in BIOS)';
    } else {
        $kvm_status = 'unsupported';
        $kvm_details = 'Hardware Virtualization Not Supported';
    }
}

$gpu_info = [];
$gpus_file = '/var/run/nix-detected-gpus.json';
$gpu_json = shell_exec('cat ' . escapeshellarg($gpus_file) . ' 2>/dev/null');
if ($gpu_json) {
    $gpus_data = json_decode($gpu_json, true);
    if (is_array($gpus_data)) {
        foreach ($gpus_data as $g) {
            if (isset($g['name'])) {
                $gpu_info[] = $g['name'];
            }
        }
    }
}
if (empty($gpu_info)) {
    $gpu_info[] = "No compatible GPUs detected (NVIDIA/AMD/Intel)";
}
?>

