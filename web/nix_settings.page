<div class="nix-section">
    <h3>Nix Package Manager Settings</h3>
    <p class="nix-subtext">Configure local storage path bindings and system-level operations.</p>
    
    <form id="nix-settings-form" onsubmit="saveSettings(event)">
        <div class="nix-form-group">
            <label for="settings-store-path">Nix Store Path (SSD Cache / ZFS Dataset Recommended):</label>
            <input type="text" id="settings-store-path" autocomplete="off" spellcheck="false" value="<?php echo htmlspecialchars($store_path); ?>" placeholder="/mnt/cache/system/nix" data-pickcloseonfile="true" data-pickfilter="HIDE_FILES_FILTER" data-pickroot="/mnt" data-pickfolders="true" required>
            <div class="nix-field-help">This is where the persistent `/nix` directory will be bind-mounted. Do NOT use your USB boot drive `/boot`.</div>
        </div>

        <div class="nix-form-group">
            <label for="settings-autostart">Autostart Nix Flakes Services on Array Start:</label>
            <select id="settings-autostart">
                <option value="yes" <?php echo $autostart === 'yes' ? 'selected' : ''; ?>>Yes</option>
                <option value="no" <?php echo $autostart === 'no' ? 'selected' : ''; ?>>No</option>
            </select>
        </div>

        <div class="nix-form-group">
            <label for="settings-enable-cli">Show CLI Package Installation option in Flake Store:</label>
            <select id="settings-enable-cli">
                <option value="no" <?php echo $enable_cli === 'no' ? 'selected' : ''; ?>>No (Services only)</option>
                <option value="yes" <?php echo $enable_cli === 'yes' ? 'selected' : ''; ?>>Yes (Show CLI option)</option>
            </select>
        </div>

        <button type="submit" class="nix-btn-primary">Apply Settings</button>
    </form>
</div>

<script>
$(function() {
    if (typeof $.fn.fileTreeAttach === 'function') {
        $("#settings-store-path").fileTreeAttach();
    }
});

function saveSettings(e) {
    e.preventDefault();
    var path = $("#settings-store-path").val();
    var auto = $("#settings-autostart").val();
    var enableCli = $("#settings-enable-cli").val();
    
    if (path.indexOf("/boot") === 0) {
        alert("Error: The Nix Store cannot be stored on your USB flash drive (/boot). Choose a pool disk or array share.");
        return;
    }
    
    $.post('/plugins/nix/api.php', {
        action: 'save-settings',
        store_path: path,
        autostart: auto,
        enable_cli: enableCli
    }, function(resp) {
        if (resp.success) {
            alert("Settings applied successfully! Restart the Nix services for the changes to take effect.");
            location.reload();
        } else {
            alert("Failed to save settings: " + resp.error);
        }
    }, 'json');
}

function toggleNixDaemon(action) {
    var btnContainer = document.getElementById('nix-daemon-controls');
    btnContainer.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Processing...';
    
    $.post('/plugins/nix/api.php', { action: 'nix-daemon-' + action }, function(response) {
        if (response.success) {
            location.reload();
        } else {
            alert("Action failed: " + response.error);
            location.reload();
        }
    }, 'json');
}
</script>

