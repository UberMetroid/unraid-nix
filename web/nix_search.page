Menu="nix:2"
Title="Flake Store"
---
<link type="text/css" rel="stylesheet" href="/plugins/nix/styles.css">
<div class="nix-section">
    <h3>Search Nixpkgs Registry</h3>
    <p class="nix-subtext">Search the official Nix repository containing over 100,000 native packages.</p>
    
    <div class="nix-search-bar">
        <input type="text" id="nix-search-input" placeholder="Search packages (e.g. ripgrep, fd, jellyfin)..." onkeyup="if(event.keyCode==13) executeSearch()">
        <button class="nix-btn-primary" onclick="executeSearch()"><i class="fa fa-search"></i> Search</button>
    </div>

    <div id="nix-search-results" class="nix-results-container">
        <!-- Rendered dynamically by AJAX -->
        <p class="text-muted text-center">Enter a query and click search.</p>
    </div>
</div>

<script>
function executeSearch() {
    var query = $("#nix-search-input").val();
    if (!query.trim()) return;
    $("#nix-search-results").html('<div class="nix-spinner"><i class="fa fa-spinner fa-spin"></i> Searching Nix registry...</div>');
    $.get('/plugins/nix/api.php?action=search&q=' + encodeURIComponent(query), function(html) {
        $("#nix-search-results").html(html);
    });
}

function installPackage(pkg) {
    if (!confirm("Are you sure you want to install CLI package: " + pkg + "?")) return;
    $.post('/plugins/nix/api.php', { action: 'install-cli', package: pkg }, function(resp) {
        if (resp.success) {
            alert(pkg + " successfully installed in your global Nix profile!");
        } else {
            alert("Installation failed: " + resp.error);
        }
    }, 'json');
}
</script>

