#!/bin/bash
# /etc/rc.d/rc.nix-daemon
# Control script for the Nix daemon on Slackware/Unraid.

DAEMON="/nix/var/nix/profiles/default/bin/nix-daemon"
PIDFILE="/var/run/nix-daemon.pid"

start() {
    if [ -f "$PIDFILE" ]; then
        PID=$(cat "$PIDFILE")
        if [ -n "$PID" ] && [ -d "/proc/$PID" ]; then
            echo "nix-daemon is already running."
            return
        fi
    fi
    
    if [ ! -x "$DAEMON" ]; then
        echo "nix-daemon executable not found. Is Nix installed?"
        return 1
    fi

    echo "Starting nix-daemon..."
    # Execute the daemon in the background
    $DAEMON >/var/log/nix-daemon.log 2>&1 &
    echo $! > "$PIDFILE"
    echo "nix-daemon started."
}

stop() {
    if [ -f "$PIDFILE" ]; then
        echo "Stopping nix-daemon..."
        PID=$(cat "$PIDFILE")
        kill "$PID" >/dev/null 2>&1
        rm -f "$PIDFILE"
        echo "nix-daemon stopped."
    else
        echo "nix-daemon is not running."
    fi
}

status() {
    if [ -f "$PIDFILE" ]; then
        PID=$(cat "$PIDFILE")
        if [ -n "$PID" ] && [ -d "/proc/$PID" ]; then
            echo "nix-daemon is running (pid $PID)."
            return 0
        fi
    fi
    echo "nix-daemon is stopped."
    return 3
}

case "$1" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    status)
        status
        ;;
    restart)
        stop
        sleep 1
        start
        ;;
    *)
        echo "Usage: $0 {start|stop|status|restart}"
        exit 1
esac
